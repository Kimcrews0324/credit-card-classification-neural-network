{
 "cells": [
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "14c4f266-b578-4e32-8e7b-5f519049f991",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Kimberly Crews\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from sklearn.metrics import confusion_matrix, accuracy_score\n",
    "import seaborn as sns\n",
    "import matplotlib.pyplot as plt"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "dca7facf-0f86-4065-869c-e759485e1a9e",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Dataset:\n",
      "   Years  Salary  UsedCredit\n",
      "0      4      43           0\n",
      "1     18      65           1\n",
      "2      1      53           0\n",
      "3      3      95           0\n",
      "4     15      88           1\n",
      "5      6     112           1\n"
     ]
    }
   ],
   "source": [
    "# Dataset from Table\n",
    "data = {\n",
    "    'Years':  [4, 18, 1, 3, 15, 6],\n",
    "    'Salary': [43, 65, 53, 95, 88, 112],\n",
    "    'UsedCredit': [0, 1, 0, 0, 1, 1]\n",
    "}\n",
    "\n",
    "df = pd.DataFrame(data)\n",
    "print(\"Dataset:\")\n",
    "print(df)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "c6ec2880-d786-4759-942d-d6fa85db334e",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Normalized Inputs:\n",
      "[[0.17647059 0.        ]\n",
      " [1.         0.31884058]\n",
      " [0.         0.14492754]\n",
      " [0.11764706 0.75362319]\n",
      " [0.82352941 0.65217391]\n",
      " [0.29411765 1.        ]]\n"
     ]
    }
   ],
   "source": [
    "# Normalize inputs to [0, 1] range\n",
    "X = df[['Years', 'Salary']].values\n",
    "y = df['UsedCredit'].values.reshape(-1, 1)\n",
    "\n",
    "X_norm = (X - X.min(axis=0)) / (X.max(axis=0) - X.min(axis=0))\n",
    "print(\"Normalized Inputs:\")\n",
    "print(X_norm)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "3af69ce5-50a3-4dae-a401-558069bb7a0a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "W1 (input → hidden):\n",
      " [[0.37454012 0.95071431]\n",
      " [0.73199394 0.59865848]]\n",
      "b1 (hidden bias):\n",
      " [[0.15601864 0.15599452]]\n",
      "W2 (hidden → output):\n",
      " [[0.05808361]\n",
      " [0.86617615]]\n",
      "b2 (output bias):\n",
      " [[0.60111501]]\n"
     ]
    }
   ],
   "source": [
    "np.random.seed(42)  # For reproducibility\n",
    "\n",
    "# Network architecture: 2 inputs → 2 hidden nodes → 1 output\n",
    "# Weights: input → hidden layer\n",
    "W1 = np.random.rand(2, 2)\n",
    "b1 = np.random.rand(1, 2)\n",
    "\n",
    "# Weights: hidden → output layer\n",
    "W2 = np.random.rand(2, 1)\n",
    "b2 = np.random.rand(1, 1)\n",
    "\n",
    "print(\"W1 (input → hidden):\\n\", W1)\n",
    "print(\"b1 (hidden bias):\\n\", b1)\n",
    "print(\"W2 (hidden → output):\\n\", W2)\n",
    "print(\"b2 (output bias):\\n\", b2)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "f7808638-beef-4f6e-9009-f6c6c8cc0b3a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Sigmoid function defined.\n"
     ]
    }
   ],
   "source": [
    "def sigmoid(z):\n",
    "    return 1 / (1 + np.exp(-z))\n",
    "\n",
    "print(\"Sigmoid function defined.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "bd9dafc7-3e77-4f0f-92c7-514e3f932470",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Hidden Layer Output (A1):\n",
      "[[0.55530132 0.58024218]\n",
      " [0.6822103  0.78542834]\n",
      " [0.56515361 0.56039286]\n",
      " [0.6795555  0.67238813]\n",
      " [0.71947336 0.79073561]\n",
      " [0.73069891 0.73774383]]\n",
      "\n",
      "Final Output (A2 - predicted probabilities):\n",
      "[[0.75693727]\n",
      " [0.78935793]\n",
      " [0.75386629]\n",
      " [0.77258976]\n",
      " [0.79047996]\n",
      " [0.7828874 ]]\n"
     ]
    }
   ],
   "source": [
    "# Hidden layer\n",
    "Z1 = np.dot(X_norm, W1) + b1\n",
    "A1 = sigmoid(Z1)\n",
    "\n",
    "# Output layer\n",
    "Z2 = np.dot(A1, W2) + b2\n",
    "A2 = sigmoid(Z2)\n",
    "\n",
    "print(\"Hidden Layer Output (A1):\")\n",
    "print(A1)\n",
    "print(\"\\nFinal Output (A2 - predicted probabilities):\")\n",
    "print(A2)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "34d3a644-d9c4-4c42-99fb-00e2e56c1479",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Predicted Labels: [1 1 1 1 1 1]\n",
      "Actual Labels:    [0 1 0 0 1 1]\n"
     ]
    }
   ],
   "source": [
    "# Threshold at 0.5\n",
    "y_pred = (A2 >= 0.5).astype(int)\n",
    "\n",
    "print(\"Predicted Labels:\", y_pred.flatten())\n",
    "print(\"Actual Labels:   \", y.flatten())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "8b9f2a02-0fc8-49ea-aba4-36a39afcf58b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Confusion Matrix:\n",
      "[[0 3]\n",
      " [0 3]]\n",
      "\n",
      "Accuracy: 50.00%\n"
     ]
    }
   ],
   "source": [
    "cm = confusion_matrix(y, y_pred)\n",
    "acc = accuracy_score(y, y_pred)\n",
    "\n",
    "print(\"Confusion Matrix:\")\n",
    "print(cm)\n",
    "print(f\"\\nAccuracy: {acc * 100:.2f}%\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "6636cd39-56fd-4b02-87f0-7c11bf8080b6",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 500x400 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "plt.figure(figsize=(5, 4))\n",
    "sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',\n",
    "            xticklabels=['Pred: 0', 'Pred: 1'],\n",
    "            yticklabels=['Actual: 0', 'Actual: 1'])\n",
    "plt.title('Confusion Matrix – Credit Card Neural Network')\n",
    "plt.ylabel('Actual')\n",
    "plt.xlabel('Predicted')\n",
    "plt.tight_layout()\n",
    "plt.savefig('confusion_matrix.png', dpi=150)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "ea039f39-a68a-405a-8873-cf8dbe37d223",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Summary Table:\n",
      "   Years  Salary  Actual  Predicted\n",
      "0      4      43       0          1\n",
      "1     18      65       1          1\n",
      "2      1      53       0          1\n",
      "3      3      95       0          1\n",
      "4     15      88       1          1\n",
      "5      6     112       1          1\n"
     ]
    }
   ],
   "source": [
    "results_df = pd.DataFrame({\n",
    "    'Years': df['Years'],\n",
    "    'Salary': df['Salary'],\n",
    "    'Actual': y.flatten(),\n",
    "    'Predicted': y_pred.flatten()\n",
    "})\n",
    "print(\"Summary Table:\")\n",
    "print(results_df)"
   ]
  }
 ],
